# Copy to .env and fill in. .env is gitignored — never commit real values.

# Israel Railways API
RAIL_URL=https://rail-api.rail.co.il/rjpa/api/v1
RAIL_API_KEY=

# The bot reaches signal-cli ONLY through its own wrapper (sender-binding proxy).
SIGNAL_API_URL=http://wrapper-train:8080
# This bot's fixed Signal sender number (E.164). Used by wrapper-train (BOT_NUMBER)
# and as the receive number. Not a secret, but kept out of source.
BOT_NUMBER=

# Bearer token (for /v2/send + the receive WS) is NOT set here — it lives only in
# the Docker secret ./secrets/signal_token, read by both the bot and its wrapper via
# SIGNAL_TOKEN_FILE. Create it: openssl rand -hex 32 > ./secrets/signal_token

# The existing Docker network the shared signal-cli container is on (docker network ls).
SIGNAL_NETWORK=signal-net
# The shared signal-cli's URL on that network — its service alias varies by host
# (find it with: docker inspect <signal-cli container> for its network alias).
SIGNAL_BACKEND_URL=http://signal-api:8080

# A long random string (>=16 chars) used to salt the sender-id HMAC in logs.
# Generate: openssl rand -hex 24
LOG_SALT=

TZ=Asia/Jerusalem
CONFIG_PATH=./config.yaml
