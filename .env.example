# Copy to .env and fill in. .env is gitignored — never commit real values.

# Israel Railways API
RAIL_URL=https://rail-api.rail.co.il/rjpa/api/v1
RAIL_API_KEY=

# signal-cli-rest-api: the URL the bot uses to reach it (service name + internal port)
SIGNAL_API_URL=http://signal-cli:8080
# The existing Docker network your signal-cli container is on (docker network ls)
SIGNAL_NETWORK=signal-net

# A long random string (>=16 chars) used to salt the sender-id HMAC in logs.
# Generate: openssl rand -hex 24
LOG_SALT=

TZ=Asia/Jerusalem
CONFIG_PATH=./config.yaml
