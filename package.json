{
  "name": "train-notifier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "test": "node --test 'src/**/*.test.ts'",
    "test:e2e": "RAIL_E2E=1 node --test --env-file=.env src/pipeline.e2e.test.ts",
    "start": "node src/app.ts"
  },
  "dependencies": {
    "node-cron": "^4.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.0"
  }
}
